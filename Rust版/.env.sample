# このファイル名を .env に変更すると設定が有効になります。
# サーバーの待受ポート番号（既定は80）
RPC_PORT=80

# Gmail API の credentials.json のパス
# GMAIL_CREDENTIALS_JSON=.\\gmail_api_credentials\\credentials.json
# Gmail API の token.json のパス
# GMAIL_TOKEN_JSON=.\\gmail_api_credentials\\token.json
# 送信元メールアドレス（From）
# EMAIL_SENDER=roboken.report.tool@gmail.com
# 送信者名（メール表示名）
# EMAIL_DISPLAY_NAME=ロボ研報告書作成ツール

# SMTPサーバーのホスト名（Gmail API失敗時のフォールバック）
# SMTP_HOST=smtp.example.com
# SMTPサーバーのポート番号
# SMTP_PORT=587
# SMTP認証ユーザー名
# SMTP_USER=user@example.com
# SMTP認証パスワード
# SMTP_PASS=change_me
# SMTPの送信元アドレス（未指定時はSMTP_USERを利用）
# SMTP_FROM=user@example.com
# SMTPの送信者名
# SMTP_FROM_NAME=Report PDF Converter
